# Flask Configuration
FLASK_ENV=production
SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=False

# Application Settings
CTF_NAME=My CTF Event
CTF_DESCRIPTION=An awesome CTF competition
REGISTRATION_ENABLED=True

DECAY_FUNCTION=logarithmic

# Database Configuration (for Docker deployment)
# Use the service name 'mongo' as the host
MONGODB_URI=mongodb://admin:password@mongo:27017/ctf_platform?authSource=admin

# MongoDB Root Credentials (for Docker)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password

# Redis Configuration (for Docker deployment)
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_URL=redis://cache:6379/0

# File Upload Settings
UPLOAD_FOLDER=/var/uploads
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=txt,pdf,zip,png,jpg,jpeg,gif,tar,gz,py,c,cpp,java,js,html,css

# Logging
LOG_FOLDER=/var/log/CTFd
ACCESS_LOG=-
ERROR_LOG=-

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Docker-specific settings
AUTO_INIT_DB=false
WITH_SAMPLE_DATA=false
REVERSE_PROXY=true


